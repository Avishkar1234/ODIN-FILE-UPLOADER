<!DOCTYPE html>
<html>
<head>
  <title><%= file.name %></title>
</head>
<body>
  <h2>File Details</h2>
  <p><strong>Name:</strong> <%= file.name %></p>
  <p><strong>Size:</strong> <%= file.size %> bytes</p>
  <p><strong>Uploaded At:</strong> <%= file.createdAt %></p>
  <a href="<%= file.path %>" target="_blank">View File</a>
  &nbsp;
  <a href="/files/<%= file.id %>/download">Download</a>  <br><br>
  <a href="/dashboard">Back to Dashboard</a>
</body>
</html>